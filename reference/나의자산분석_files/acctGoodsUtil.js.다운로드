	o.getAcctGoods = function(acctNo, searchType){
		
		var d=$.Deferred();
		
		if(util.isNull(acctNo)||util.isEmpty(acctNo)){
			d.reject();
			return;
		}
		
		if(util.isNull(searchType)||util.isEmpty(searchType)){
			d.reject();
			return;
		}
	    var prm = {
	    	acctNo : acctNo,
	    	searchType : searchType,
	    	serviceType : "getAcctGoods"
	    }
		http.post('/siw/myasset/details/acctGoodsUtil/data.do', prm, false).then(function(rsHttp) {
			if(rsHttp.ErrType!='0'){
				log(rsHttp.errorMsg)
				d.reject();
				return;
			}
			var result = rsHttp['반복데이타0'];
			var returnArr = [];
			
			_.each(result, function(data, index, dataList){
				returnArr.push({text:data[0]+' '+data[1], value:data[0]});
			});
			d.resolve(returnArr);
			
		});
		return d.promise();
	}
	
	o.getAcctGoods2 = function(acctNo, gubn){
		
		var d=$.Deferred();
		
		
		if(util.isNull(gubn)){
		    //0:전체
	        //1:주식
	        //2:증권상품
	        //3:선물
			gubn = 0;
		}
		if(util.isNull(acctNo)||util.isEmpty(acctNo)){
			d.reject();
			return;
		}

	    var prm = {
			acctNo : acctNo,
			serviceType : "getAcctGoods2"
		}
		http.post('/siw/myasset/details/acctGoodsUtil/data.do', prm, false).then(function(rsHttp) {
			if(rsHttp.ErrType!='0'){
				log(rsHttp.errorMsg)
				d.reject();
				return;
			}
			var returnArr = [];
			var goodsCnt = Number(rsHttp['상품갯수']);
			
			for(var i=0; i<goodsCnt; i++){
				var code = rsHttp['상품번호'].substring(i*2, i*2+2);
				returnArr.push({text:code+' '+o.getLabel(code), value:code});
			}
			
			
			if(gubn==1){
				returnArr = _.filter(returnArr, function(data){
					return data.value.indexOf('0')==0 || data.value.indexOf('2')==0 || data.value.indexOf('7')==0 
				});
			}else if(gubn==2){
				returnArr = _.filter(returnArr, function(data){
					return data.value.indexOf('2')==0
				});
			}else if(gubn==3){
				returnArr = _.filter(returnArr, function(data){
					return data.value.indexOf('1')==0
				});
			}
			
			d.resolve(returnArr);
			
		});
		return d.promise();
	}
