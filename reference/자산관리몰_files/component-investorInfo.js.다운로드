(function (){

si.component('investorInfo', function($svc) {
	var log = $svc.logger('investorInfo');
	var http = $svc.get('http');
	var wpopup = $svc.get('wpopup');
	
	var lc = {};
	var vl = {};
	var on = {};
	
	return {
		viewModel: function(params) {
			//
			log("params = ", params);
			this.vl = params;
			this.on = {};
			vl = this.vl;
			on = this.on;
			
			// 변수관리
			// ==================================================
			vl.investorType = ko.observable('');	//개인/법인구분
			vl.custName = ko.observable('');
			vl.generalTp = ko.observable('');
			vl.generalTpName = ko.observable('');
			vl.derivativeTp = ko.observable('');
			vl.derivativeTpName = ko.observable('');
			vl.limitDate = ko.observable('');
			vl.lastRegiYmd = ko.observable('');
			vl.investInfoAgree = ko.observable('');
			vl.investPersuasion1 = ko.observable('');
			vl.custGubun = ko.observable('');		//일반/전분투자자 구분
			vl.currentInvestorTendency 	= ko.observable(false);
			// 이벤트 함수 관리
			// ==================================================
			
			vl.init = init;
			
			// 지역함수
			// ==================================================
			//개인/법인 구분
			function init() {
				if (params.iscurrentInvestorTendency) {
					vl.currentInvestorTendency(true);
				}
				
				http.post("/siw/banking-lending/customer-info/59730101/data.do", {}, false).then(function(body) {
					log("59730101 body : ", body);
					if(body && body.result) {
						vl.investorType(body['개인법인구분']);
						
						vl.custName(body['사용자이름']);
						vl.generalTp(body['투자성향등급']);
						vl.generalTpName(body['투자성향등급명']);
						vl.derivativeTp(body['파생투자성향등급']); 
						vl.derivativeTpName(body['파생투자성향등급명']); 
						vl.limitDate(body['만기일자']);
						vl.lastRegiYmd(body['투자성향최종등록일자']);
						vl.investInfoAgree(body['정보제공동의여부']);
						vl.investPersuasion1(body['금융투자상품투자권유']);
						vl.custGubun(body['투자자구분']);	//2017-03-09 추가
						
						if (vl.custGubun() == '2') {
							$svc.get('lpopup').alert("고객님은 현재 전문투자자입니다.<br/>투자정보확인서 등록 시 일반투자자로 전환됩니다. 등록하시겠습니까?");
						}
					}
				}, function(error) {
					log("http reject!!!");
					//개인/법인 조회 실패시, 에러처리
					page.error();
				});
			}
			//
			init();
			
			// 현투 성향일 경우에만 스크롤 이동 하도록 설정
			if (vl.currentInvestorTendency()) {
				// 바인딩 등록 
				ko.bindingHandlers.ready = {
					init: function (el) {
						// 하위 데이터 바인딩(ko if) 완료 시점 때문에 0.005초 딜레이 
						setTimeout(function() {
							const isSkip = document.querySelector('.readonly_end');
							if(isSkip) {
								isSkip.scrollIntoView({
									behavior: 'smooth',
									block: 'start'
								})
							}
						}, 5);
					}
				}
			}
		},
		template: $svc.get('http').html('/siw/common/biz/common/component-investorInfo.html')
	}
});

