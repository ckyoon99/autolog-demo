							$('#investor_radio3_4_1').focus();
						});
						return false;
					}
					//금융투자상품 투자경험이 있는 경우
					if(!vl.checkNoExp1()){
						if(!vl.s4_1_1() && !vl.s4_1_2() && !vl.s4_1_3() && !vl.s4_1_4() && !vl.s4_1_5()) {
							lpopup.alert("5번 [금융투자상품 투자경험] 투자 경험이 있는 경우, 금융투자상품을 선택해 주세요.").then(function() {
								$("#investor_check1_1").focus();
							});
