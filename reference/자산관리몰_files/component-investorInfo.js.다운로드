			function calAge(birth){
				var d = new Date();
				var year = d.getFullYear() + '';
				var month = d.getMonth() + 1 + '';
				var day = d.getDate() + '';
				
				//월 2자리로 맞춤
				if(month.length < 2) {
				    month = '0'+month;
				}
				//일 2자리로 맞춤
				if(day.length < 2) {
				    day = '0'+day;
				}
				
				var today = month+day;
				
				//고객생일년도
				targetYear = birth.substr(0, 4);
				//고객생일월일
				targetbirth = birth.substring(4);
				
				var age = year - targetYear;
				
				//생일이 아직 안지났을때
				if(today < targetbirth) {
				    return age - 1;
				}
				return age;
			}
