	//"Y" --> ture, "N" --> false
	function strToBool(str) {
		if(str=="Y") return true;
		else return false;
	}
	//ture --> "Y",  false--> "N"
	function boolToStr(bol, gubn) {
		if(util.isNull(gubn)){
			if(bol)return "Y";
			else return "N";
		}else{
			if(bol)return "1";
			else return "0";
		}
	}
