    				else
    				{
    					alert("Cloudrevoke 실패 : [" + res.code + "]" + res.message);
    				}
    			}
    			CloudCert.CloudRevoke(options,callback);
    		} else {
    				alert("ClearSession 실패 : [" + res.code + "]" + res.message);
    				return;
    		}
    	});
    }
